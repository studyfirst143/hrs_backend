{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    // ✅ NodeNext for modern ESM in Node
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "es2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx"
  }
}
